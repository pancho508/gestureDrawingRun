# PostgreSQL database URL
# Format: postgresql://user:password@host:port/database
# Examples:
#   Local: postgresql://postgres:password@localhost:5432/gesture_drawing
#   Neon: postgresql://user:password@ep-xxx-xxx-xxx.us-east-1.postgres.vercel.io/gesture_drawing
#   Supabase: postgresql://postgres.xxx:password@aws-0-us-east-1.pooler.supabase.com:6543/gesture_drawing
#   AWS RDS: postgresql://admin:password@mydb.xxxxx.us-east-1.rds.amazonaws.com:5432/gesture_drawing

DATABASE_URL=postgresql://user:password@localhost:5432/gesture_drawing

# Admin Authentication
# Change these values in production!
ADMIN_PASSWORD=admin123
ADMIN_TOKEN=admin_secret_token_change_me
